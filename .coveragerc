[run]
# Trust-store variant files are script-generated byte-for-byte from their
# source plugin (scripts/make_truststore.py, scripts/make_pubchem_truststore.py)
# with only an SSL-injection header added. They are near-duplicates of the
# already-tested originals, so they are excluded from coverage rather than
# tested redundantly.
omit =
    */_truststore.py
    */*_truststore.py
